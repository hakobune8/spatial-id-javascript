{
  "name": "@hakobune8/spatial-id-javascript",
  "version": "0.2.0",
  "description": "JavaScript implementation of the Ouranos GEX Spatial ID specification.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest --runInBand",
    "test:package": "node scripts/test-package.mjs",
    "prepack": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hakobune8/spatial-id-javascript.git"
  },
  "keywords": [
    "spatial-id",
    "zfxy",
    "gis"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hakobune8/spatial-id-javascript/issues"
  },
  "homepage": "https://github.com/hakobune8/spatial-id-javascript#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "dependencies": {
    "@turf/bbox": "^6.5.0",
    "@turf/boolean-intersects": "^6.5.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^22.0.0",
    "@rollup/plugin-node-resolve": "^13.2.1",
    "@types/geojson": "^7946.0.8",
    "@types/jest": "^27.4.1",
    "jest": "^27.5.1",
    "rollup": "^2.70.2",
    "rollup-plugin-typescript2": "^0.31.2",
    "ts-jest": "^27.1.4",
    "typescript": "^4.6.3"
  }
}
